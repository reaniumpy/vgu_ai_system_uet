# Python virtual environment - recreate with the Setup steps in README.md
.venv/

# Python bytecode/cache
__pycache__/
*.pyc

# Downloaded model weights, if ever cached inside the repo instead of
# the default ~/.cache/huggingface - guardrail.py downloads these on
# demand the first time it runs, so they should never be committed.
models/
*.safetensors
*.bin

# Local secrets (API keys for a future --call-model step)
.env

# Per-developer Claude Code permission settings, not shared config
.claude/settings.local.json

# OS cruft
.DS_Store
